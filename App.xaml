<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Theme color - Support dark mode -->
            <Color x:Key="LightBackground">#F8F9FA</Color>
            <Color x:Key="DarkBackground">#1A1A1E</Color>

            <Color x:Key="LightCardBackground">#FFFFFF</Color>
            <Color x:Key="DarkCardBackground">#2C2C2E</Color>

            <Color x:Key="LightText">#1F1F1F</Color>
            <Color x:Key="DarkText">#FFFFFF</Color>

            <Color x:Key="LightSubText">#6C757D</Color>
            <Color x:Key="DarkSubText">#8E8E93</Color>

            <!-- Main color (unchanged according to the theme) -->
            <Color x:Key="Primary">#2196F3</Color>
            <Color x:Key="Success">#4CAF50</Color>
            <Color x:Key="Danger">#F44336</Color>
            <Color x:Key="Warning">#FF9800</Color>

            <!--Global page style  -->
            <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
                <Setter Property="BackgroundColor" 
                        Value="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}" />
            </Style>

            <!-- Global label style-->
            <Style TargetType="Label">
                <Setter Property="TextColor" 
                        Value="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}" />
            </Style>

            <!-- Card style -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="12" />
                    </Setter.Value>
                </Setter>
                <Setter Property="BackgroundColor" 
                        Value="{AppThemeBinding Light={StaticResource LightCardBackground}, Dark={StaticResource DarkCardBackground}}" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="#1A000000" Offset="0,2" Radius="4" Opacity="0.25" />
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>