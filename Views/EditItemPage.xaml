<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodApp.Views.EditItemPage"
             Title="Edit Food Item"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">

    <ScrollView>
        <VerticalStackLayout Padding="16,12" Spacing="16">

            <Label Text="✏️ Edit Food Information"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                   SemanticProperties.HeadingLevel="Level1" />

            <!-- 照片显示区域 -->
            <Border IsVisible="{Binding HasPhoto}"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3C}"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBackground}, Dark={StaticResource DarkCardBackground}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="📷 Current Photo"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}" />
                    <Image Source="{Binding CurrentItem.PhotoPath}"
                           Aspect="AspectFill"
                           HeightRequest="150"
                           HorizontalOptions="Center"
                           SemanticProperties.Description="Food photo" />
                    <Button Text="🗑️ Delete Photo"
                            BackgroundColor="#F44336"
                            TextColor="White"
                            Command="{Binding DeletePhotoCommand}"
                            CornerRadius="8"
                            SemanticProperties.Hint="Delete this photo" />
                </VerticalStackLayout>
            </Border>

            <!-- 无照片提示 -->
            <Border IsVisible="{Binding HasNoPhoto}"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3C}"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBackground}, Dark={StaticResource DarkCardBackground}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="📷 No Photo"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#6C757D, Dark=#8E8E93}"
                           HorizontalOptions="Center" />
                    <Label Text="You can take a photo in the detail page"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#6C757D, Dark=#8E8E93}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- 基本信息卡片 -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3C}"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBackground}, Dark={StaticResource DarkCardBackground}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Basic Information"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}" />

                    <Entry Placeholder="Food Name *"
                           Text="{Binding CurrentItem.Name}"
                           BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                           PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />

                    <Picker Title="Category *"
                            TitleColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}"
                            TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                            SelectedItem="{Binding CurrentItem.Category}">
                        <Picker.Items>
                            <x:String>Breakfast</x:String>
                            <x:String>Lunch</x:String>
                            <x:String>Dinner</x:String>
                            <x:String>Snack</x:String>
                            <x:String>Drink</x:String>
                        </Picker.Items>
                    </Picker>

                    <Editor Placeholder="Description"
                            Text="{Binding CurrentItem.Description}"
                            HeightRequest="100"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                            TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                            PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}"
                            AutoSize="TextChanges" />
                </VerticalStackLayout>
            </Border>

            <!-- 营养信息卡片 -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3C}"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBackground}, Dark={StaticResource DarkCardBackground}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Nutrition (per serving)"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}" />

                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <Entry Placeholder="Calories *"
                               Text="{Binding CurrentItem.Calories}"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />
                        <Entry Grid.Column="1"
                               Placeholder="Protein"
                               Text="{Binding CurrentItem.Protein}"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />
                        <Entry Grid.Column="2"
                               Placeholder="Carbs"
                               Text="{Binding CurrentItem.Carbs}"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />
                        <Entry Grid.Column="3"
                               Placeholder="Fat"
                               Text="{Binding CurrentItem.Fat}"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />
                    </Grid>

                    <Entry Placeholder="Allergy Information (optional)"
                           Text="{Binding CurrentItem.AllergyInfo}"
                           BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                           PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />
                </VerticalStackLayout>
            </Border>

            <!-- 按钮 -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                <Button Text="Cancel"
                        BackgroundColor="#9E9E9E"
                        TextColor="White"
                        Command="{Binding CancelCommand}"
                        CornerRadius="8" />
                <Button Grid.Column="1"
                        Text="Save"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        Command="{Binding SaveCommand}"
                        CornerRadius="8" />
            </Grid>

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="#2196F3" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>