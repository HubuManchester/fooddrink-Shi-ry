<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodApp.Models"
             xmlns:viewmodels="clr-namespace:FoodApp.ViewModels"
             x:Class="FoodApp.Views.MainPage"
             Title="{Binding Title}"
             BackgroundColor="White"
             x:DataType="viewmodels:MainViewModel">

	<Grid RowDefinitions="Auto, *, Auto">

		<!-- Top Header -->
		<Border Grid.Row="0"
                BackgroundColor="#2196F3"
                Padding="16,20">
			<VerticalStackLayout>
				<Label Text="Food Explorer"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White" />
				<Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,12,0,0">
					<SearchBar x:Name="SearchBar"
                               Placeholder="Search foods..."
                               Text="{Binding SearchText}"
                               BackgroundColor="White" />
					<Button Grid.Column="1"
                            Text="Add"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            Command="{Binding AddItemCommand}" />
				</Grid>
			</VerticalStackLayout>
		</Border>

		<!-- Main List - No RefreshView, No Shadow -->
		<CollectionView Grid.Row="1"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None"
                        Margin="12,0,12,0">
			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="models:FoodItem">
					<Grid Padding="12,8"
                          ColumnDefinitions="*,Auto"
                          BackgroundColor="#F8F9FA"
                          Margin="0,4">
						<VerticalStackLayout>
							<Label Text="{Binding Name}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#333333" />
							<Label Text="{Binding Description}"
                                   FontSize="13"
                                   TextColor="#666666"
                                   LineBreakMode="TailTruncation" />
							<Label Text="{Binding NutritionSummary}"
                                   FontSize="12"
                                   TextColor="#4CAF50" />
						</VerticalStackLayout>
						<Button Grid.Column="1"
                                Text="Details"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                CornerRadius="6"
                                WidthRequest="70"
                                HeightRequest="35"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=ViewDetailCommand}"
                                CommandParameter="{Binding .}" />
					</Grid>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<!-- Bottom Status -->
		<Label Grid.Row="2"
               Text="Ready"
               FontSize="12"
               TextColor="#666666"
               HorizontalTextAlignment="Center"
               Margin="0,8"/>

		<ActivityIndicator IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="#2196F3"
                           Grid.RowSpan="3" />
	</Grid>
</ContentPage>