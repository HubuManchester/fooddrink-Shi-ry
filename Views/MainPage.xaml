<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodApp.Models"
             xmlns:viewmodels="clr-namespace:FoodApp.ViewModels"
             x:Class="FoodApp.Views.MainPage"
             Title="{Binding Title}"
             x:DataType="viewmodels:MainViewModel">

	<Grid RowDefinitions="Auto, *">

		<!-- 顶部标题栏 -->
		<Border BackgroundColor="{StaticResource Primary}"
                Padding="16,20">
			<VerticalStackLayout>
				<Label Text="🍽️ Food Explorer"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White" />
				<Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,12,0,0">
					<SearchBar x:Name="SearchBar"
                               Placeholder="Search foods..."
                               Text="{Binding SearchText}"
                               BackgroundColor="White"
                               TextColor="{StaticResource LightText}"
                               PlaceholderColor="{StaticResource LightSubText}" />
					<Button Grid.Column="1"
                            Text="+ Add"
                            BackgroundColor="{StaticResource Success}"
                            TextColor="White"
                            CornerRadius="8"
                            Command="{Binding AddItemCommand}"
                            SemanticProperties.Hint="Add a new food item" />
				</Grid>
			</VerticalStackLayout>
		</Border>

		<!-- 刷新视图 + 列表 -->
		<RefreshView Grid.Row="1"
                     Command="{Binding LoadItemsCommand}"
                     IsRefreshing="{Binding IsBusy, Mode=OneWay}">
			<CollectionView ItemsSource="{Binding Items}"
                            SelectionMode="None"
                            Margin="12,12,12,0">

				<!-- 空状态提示 -->
				<CollectionView.EmptyView>
					<VerticalStackLayout Padding="50" Spacing="10" HorizontalOptions="Center">
						<Label Text="🍕"
                               FontSize="48"
                               HorizontalOptions="Center" />
						<Label Text="No food items found"
                               FontSize="16"
                               HorizontalOptions="Center"
                               FontAttributes="Bold" />
						<Label Text="Tap the + button to add your first food item"
                               FontSize="14"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource LightSubText}" />
					</VerticalStackLayout>
				</CollectionView.EmptyView>

				<CollectionView.ItemTemplate>
					<DataTemplate x:DataType="models:FoodItem">
						<Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
							<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
								<Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       SemanticProperties.HeadingLevel="Level2" />

								<Label Grid.Row="1"
                                       Text="{Binding Description}"
                                       FontSize="14"
                                       TextColor="{StaticResource LightSubText}"
                                       LineBreakMode="TailTruncation" />

								<HorizontalStackLayout Grid.Row="2" Spacing="12" Margin="0,8,0,0">
									<Label Text="{Binding CaloriesLabel}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Warning}" />
									<Label Text="{Binding NutritionSummary}"
                                           FontSize="13"
                                           TextColor="{StaticResource Success}" />
								</HorizontalStackLayout>

								<Button Grid.Column="1"
                                        Grid.RowSpan="3"
                                        Text="Details"
                                        BackgroundColor="{StaticResource Primary}"
                                        TextColor="White"
                                        CornerRadius="8"
                                        WidthRequest="80"
                                        HeightRequest="40"
                                        VerticalOptions="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=ViewDetailCommand}"
                                        CommandParameter="{Binding .}"
                                        SemanticProperties.Hint="View nutrition details" />
							</Grid>
						</Border>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
		</RefreshView>
	</Grid>
</ContentPage>