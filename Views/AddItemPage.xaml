<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodApp.Views.AddItemPage"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">

    <ScrollView>
        <VerticalStackLayout Padding="16,12" Spacing="16">

            <Label Text="🍽️ Add Food Item"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                   SemanticProperties.HeadingLevel="Level1" />

            <!-- basic information card -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3C}"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBackground}, Dark={StaticResource DarkCardBackground}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Basic Information"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}" />

                    <Entry Placeholder="Food Name *"
                           Text="{Binding Name}"
                           BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                           PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}"
                           SemanticProperties.Hint="Required - enter the food name" />

                    <Picker Title="Category *"
                            TitleColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}"
                            TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                            SelectedItem="{Binding Category}">
                        <Picker.Items>
                            <x:String>Breakfast</x:String>
                            <x:String>Lunch</x:String>
                            <x:String>Dinner</x:String>
                            <x:String>Snack</x:String>
                            <x:String>Drink</x:String>
                        </Picker.Items>
                    </Picker>

                    <Editor Placeholder="Description"
                            Text="{Binding Description}"
                            HeightRequest="100"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                            TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                            PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}"
                            AutoSize="TextChanges"
                            SemanticProperties.Hint="Optional description" />
                </VerticalStackLayout>
            </Border>

            <!-- Nutrition Information Card -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3C}"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource LightCardBackground}, Dark={StaticResource DarkCardBackground}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Nutrition (per serving)"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}" />

                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <Entry Placeholder="Calories *"
                               Text="{Binding Calories}"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />
                        <Entry Grid.Column="1"
                               Placeholder="Protein"
                               Text="{Binding Protein}"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />
                        <Entry Grid.Column="2"
                               Placeholder="Carbs"
                               Text="{Binding Carbs}"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />
                        <Entry Grid.Column="3"
                               Placeholder="Fat"
                               Text="{Binding Fat}"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                               TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                               PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />
                    </Grid>

                    <Entry Placeholder="Allergy Information (optional)"
                           Text="{Binding AllergyInfo}"
                           BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3C}"
                           TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"
                           PlaceholderColor="{AppThemeBinding Light=#9E9E9E, Dark=#8E8E93}" />
                </VerticalStackLayout>
            </Border>

            <!-- botton -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                <Button Text="Cancel"
                        BackgroundColor="#9E9E9E"
                        TextColor="White"
                        Command="{Binding CancelCommand}"
                        CornerRadius="8"
                        SemanticProperties.Hint="Cancel and go back" />
                <Button Grid.Column="1"
                        Text="Save"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        Command="{Binding SaveCommand}"
                        CornerRadius="8"
                        SemanticProperties.Hint="Save this food item" />
            </Grid>

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="#2196F3" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>